      {
        "id": 10,
        "title": "E2E Avg Latency: A vs B (ms)",
        "description": "Rolling 5m average E2E latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
        "datasource": { "type": "prometheus", "uid": "afho0wduon01sc" },
        "fieldConfig": {
          "defaults": {
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "pointSize": 3, "showPoints": "auto" },
            "unit": "ms",
            "color": { "mode": "palette-classic" }
          },
          "overrides": []
        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi", "sort": "desc" }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "afho0wduon01sc" },
            "expr": "sum(rate(poc_e2e_duration_seconds_sum{strategy=\"A\"}[1m])) / sum(rate(poc_e2e_duration_seconds_count{strategy=\"A\"}[1m])) * 1000",
            "legendFormat": "A: Direct"
          },
          {
            "refId": "B",
            "datasource": { "type": "prometheus", "uid": "afho0wduon01sc" },
            "expr": "sum(rate(poc_e2e_duration_seconds_sum{strategy=\"B\"}[1m])) / sum(rate(poc_e2e_duration_seconds_count{strategy=\"B\"}[1m])) * 1000",
            "legendFormat": "B: Store+Process"
          }
        ]
      },
      {
        "id": 11,
        "title": "E2E P95 Latency: A vs B (ms)",
        "description": "Rolling 5m P95 E2E latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
        "datasource": { "type": "prometheus", "uid": "afho0wduon01sc" },
        "fieldConfig": {
          "defaults": {
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "pointSize": 3, "showPoints": "auto" },
            "unit": "ms",
            "color": { "mode": "palette-classic" }
          },
          "overrides": []
        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi", "sort": "desc" }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "afho0wduon01sc" },
            "expr": "histogram_quantile(0.95, sum by (le) (rate(poc_e2e_duration_seconds_bucket{strategy=\"A\"}[1m]))) * 1000",
            "legendFormat": "A P95"
          },
          {
            "refId": "B",
            "datasource": { "type": "prometheus", "uid": "afho0wduon01sc" },
            "expr": "histogram_quantile(0.95, sum by (le) (rate(poc_e2e_duration_seconds_bucket{strategy=\"B\"}[1m]))) * 1000",
            "legendFormat": "B P95"
          }
        ]
      },
      {
        "id": 13,
        "title": "Throughput: A vs B (events/sec)",
        "description": "Rolling 5m processing throughput",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
        "datasource": { "type": "prometheus", "uid": "afho0wduon01sc" },
        "fieldConfig": {
          "defaults": {
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "pointSize": 3, "showPoints": "auto" },
