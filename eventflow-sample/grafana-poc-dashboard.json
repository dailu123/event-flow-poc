          {
            "refId": "B",
            "datasource": { "type": "prometheus", "uid": "afho0wduon01sc" },
            "expr": "sum(increase(poc_db_operation_total{strategy=\"B\"}[5m]))",
            "legendFormat": "DB 操作总次数"
          },
          {
            "refId": "C",
            "datasource": { "type": "prometheus", "uid": "afho0wduon01sc" },
            "expr": "sum(increase(poc_db_operation_duration_seconds_sum{strategy=\"B\"}[5m])) / clamp_min(sum(increase(poc_db_operation_duration_seconds_count{strategy=\"B\"}[5m])), 1e-9) * 1000",
            "legendFormat": "DB 平均耗时 (5m)"
          }
        ]
