        "targets": [
          {
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "afho0wduon01sc" },
            "expr": "sum(rate(poc_events_processed_total{strategy=\"A\"}[30s]))",
            "legendFormat": "A: Direct"
