      {
        "id": 4,
        "title": "Strategy B DB Overview",
        "description": "B策略数据库视角：处理总条数、数据库操作总次数、每次数据库操作平均耗时",
        "type": "stat",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
